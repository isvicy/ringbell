#cloud-config
hostname: ${hostname}
manage_etc_hosts: true

users:
  - name: root
    ssh_authorized_keys:
      - ${ssh_pub_key}

write_files:
  - path: /etc/sysctl.d/99-tailscale.conf
    content: |
      net.ipv4.ip_forward = 1
      net.ipv6.conf.all.forwarding = 1
%{ if length(ip_rule_bypass) > 0 ~}
  - path: /etc/systemd/system/ip-rule-override.service
    content: |
      [Unit]
      Description=Add ip rule overrides before Tailscale table 52
      After=network-online.target
      Before=tailscaled.service

      [Service]
      Type=oneshot
      RemainAfterExit=yes
%{ for cidr in ip_rule_bypass ~}
      ExecStart=/sbin/ip rule add to ${cidr} priority 2500 lookup main
%{ endfor ~}
%{ for cidr in ip_rule_bypass ~}
      ExecStop=/sbin/ip rule del to ${cidr} priority 2500 lookup main
%{ endfor ~}

      [Install]
      WantedBy=multi-user.target
%{ endif ~}

runcmd:
  - sysctl -p /etc/sysctl.d/99-tailscale.conf
  # Lean tailscale install: avoids a full `apt-get update` over the slow Debian
  # mirrors by only refreshing the tailscale apt source. The official
  # tailscale.com/install.sh runs a bulk `apt-get update` which fetches ~9 MB
  # of Debian Sources/Translations and hangs on bandwidth-constrained networks.
  - curl -fsSL https://pkgs.tailscale.com/stable/debian/bookworm.noarmor.gpg | tee /usr/share/keyrings/tailscale-archive-keyring.gpg >/dev/null
  - echo 'deb [signed-by=/usr/share/keyrings/tailscale-archive-keyring.gpg] https://pkgs.tailscale.com/stable/debian bookworm main' > /etc/apt/sources.list.d/tailscale.list
  - apt-get -o Dir::Etc::sourcelist="sources.list.d/tailscale.list" -o Dir::Etc::sourceparts="-" -o APT::Get::List-Cleanup="0" update
  - apt-get install -y --no-install-recommends tailscale
  - systemctl enable --now tailscaled
  - tailscale up --authkey="${tailscale_auth_key}" --advertise-routes=${routes} --accept-dns=false --hostname=${hostname}%{ if accept_routes } --accept-routes%{ endif }%{ if exit_node } --advertise-exit-node%{ endif }
%{ if length(ip_rule_bypass) > 0 ~}
  - systemctl daemon-reload
  - systemctl enable --now ip-rule-override.service
%{ endif ~}
